# PRMS Mobile — Environment Configuration
# Copy this file to .env and fill in the values before building.
#
# Variables are read by react-native-config at build time.
# See: https://github.com/luggit/react-native-config
#
# Android emulator: use 10.0.2.2 to reach host localhost.
# iOS simulator:    use localhost.
# Physical device:  use your LAN IP (e.g. 192.168.1.x).

# ── API ──
PRMS_API_BASE_URL=http://10.0.2.2:3000/api/v1
PRMS_WS_URL=http://10.0.2.2:3000

# ── Firebase (FCM) ──
# Obtain from Firebase Console → Project Settings → Your Apps.
# Place google-services.json in android/app/ and
# GoogleService-Info.plist in ios/ before building.
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID_ANDROID=
FIREBASE_APP_ID_IOS=
